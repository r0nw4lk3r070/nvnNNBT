{
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": "gemma3:4b-cloud",
      "provider": "ollamaCloud",
      "maxTokens": 8192,
      "contextWindowTokens": 32768,
      "temperature": 0.7,
      "maxToolIterations": 70,
      "timezone": "Europe/Brussels"
    }
  },
  "channels": {
    "sendProgress": false,
    "sendToolHints": false,
    "sendMaxRetries": 3
  },
  "providers": {
    "local": {
      "label": "Ollama (local)",
      "apiKey": "",
      "apiBase": "http://host.docker.internal:11434/v1"
    },
    "ollamaCloud": {
      "label": "Ollama Cloud",
      "apiKey": "",
      "apiBase": "http://host.docker.internal:11434/v1"
    },
    "xai": {
      "label": "xAI",
      "apiKey": "",
      "apiKeyEnv": "GROK_API_KEY",
      "apiBase": "https://api.x.ai/v1",
      "models": [
        "grok-4.20-0309-reasoning",
        "grok-4.20-0309-non-reasoning",
        "grok-4.20-multi-agent-0309",
        "grok-4-1-fast-reasoning",
        "grok-4-1-fast-non-reasoning",
        "grok-imagine-image",
        "grok-imagine-image-pro"
      ]
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 6161
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "provider": "duckduckgo"
      }
    },
    "exec": {
      "enable": true
    },
    "restrictToWorkspace": true,
    "mcpServers": {
      "factory": {
        "command": "python",
        "args": [
          "/app/mcp_factory.py"
        ],
        "env": {
          "FACTORY_BASE_URL": "http://host.docker.internal:4000"
        }
      }
    }
  }
}
