{
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": "gemma4:2b",
      "provider": "local",
      "maxTokens": 4096,
      "contextWindowTokens": 16384,
      "temperature": 0.7,
      "maxToolIterations": 10,
      "timezone": "Europe/Brussels"
    }
  },
  "channels": {
    "sendProgress": false,
    "sendToolHints": false,
    "sendMaxRetries": 3
  },
  "providers": {
    "local": {
      "label": "Local",
      "apiKey": "",
      "apiBase": "http://ollama:11434/v1"
    },
    "xai": {
      "label": "xAI",
      "apiKey": "",
      "apiKeyEnv": "GROK_API_KEY",
      "apiBase": "https://api.x.ai/v1",
      "models": [
        "grok-3-mini",
        "grok-3",
        "grok-4-1-fast-reasoning",
        "grok-imagine-image"
      ]
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 6161
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "provider": "duckduckgo"
      }
    },
    "exec": {
      "enable": true
    },
    "restrictToWorkspace": true
  }
}
