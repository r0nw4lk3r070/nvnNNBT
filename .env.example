# nvnNNBT — environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to git.
# Run setup.sh (Linux/Mac) or setup.ps1 (Windows) to create .env automatically.

# ── Ports ────────────────────────────────────────────────────────────────────
# Port the UI (nginx, main entry point) is exposed on the host
UI_PORT=7445

# Port the Factory API (FastAPI) is exposed on the host
FACTORY_PORT=4000

# Port the agent (direct access) is exposed on the host
AGENT_PORT=6161

# Port Ollama is exposed on the host (only used with bundled-ollama profile)
OLLAMA_PORT=11434

# Port Chrome DevTools Protocol is exposed on the host
CHROME_PORT=9222

# ── Factory auth ──────────────────────────────────────────────────────────────
# Shared secret the UI must send as X-Factory-Token header.
# Leave blank to disable auth (fine for local use).
FACTORY_TOKEN=

# ── Ollama ───────────────────────────────────────────────────────────────────
# URL the agent container uses to reach Ollama.
# Default: http://ollama:11434  (bundled Ollama container)
# To use Ollama running on your host machine instead:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# Default model to use (must be available in the configured LLM backend)
# AGENT_DEFAULT_MODEL=gemma4:2b

# ── Optional: xAI Grok (leave blank to disable) ──────────────────────────────
GROK_API_KEY=

# ── Agent spawning ───────────────────────────────────────────────────────────
# Absolute path to this folder on the HOST machine.
# Required for spawning agents — the API container needs host paths for bind mounts.
# Windows example:  HOST_PROJECT_PATH=e:/nvnNNBT
# Linux example:    HOST_PROJECT_PATH=/home/derek/nvnNNBT
HOST_PROJECT_PATH=

# ── Host RAM override ─────────────────────────────────────────────────────────
# Set to your physical host RAM in MB so the dashboard shows real memory.
# Example: 32768 for 32 GB. Leave 0 to use container-visible RAM.
HOST_RAM_MB=0

# ── Room chat ─────────────────────────────────────────────────────────────────
# Your display name shown on messages in the shared room.
USER_NAME=Lars

# Tailscale (or LAN) URL of your peer's factory. Leave blank to run solo.
# Example: http://100.x.x.x:4000
PEER_URL=
