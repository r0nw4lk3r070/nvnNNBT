# nvnNNBT — environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to git.

# ── Ports ────────────────────────────────────────────────────────────────────
# Port the UI (nginx, main entry point) is exposed on the host
UI_PORT=7445

# Port the API (Express proxy) is exposed on the host
API_PORT=4000

# Port the agent (direct access) is exposed on the host
AGENT_PORT=6161

# Port Ollama is exposed on the host
OLLAMA_PORT=11434

# ── API auth ─────────────────────────────────────────────────────────────────
# Set a secret key to require auth on the API.
# Leave blank to disable auth (fine for local use).
API_KEY=

# ── Ollama ───────────────────────────────────────────────────────────────────
# URL the agent container uses to reach Ollama.
# Default: http://ollama:11434  (bundled Ollama container)
# To use Ollama running on your host machine instead:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# Default model to use (must be available in the configured LLM backend)
# AGENT_DEFAULT_MODEL=gemma4:2b

# ── Optional: xAI Grok (leave blank to disable) ──────────────────────────────
GROK_API_KEY=

# ── Agent spawning ───────────────────────────────────────────────────────────
# Absolute path to this folder on the HOST machine.
# Required for spawning agents — the API container needs host paths for bind mounts.
# Windows example:  HOST_PROJECT_PATH=e:/nvnNNBT
# Linux example:    HOST_PROJECT_PATH=/home/derek/nvnNNBT
HOST_PROJECT_PATH=
